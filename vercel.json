{
    "functions": {
        "src/app/api/convert-image/route.js": {
            "memory": 1024,
            "maxDuration": 30
        },
        "src/app/api/docs-to-pdf/route.js": {
            "memory": 1024,
            "maxDuration": 60
        }
    },
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                }
            ]
        }
    ]
}